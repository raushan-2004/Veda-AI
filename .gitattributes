# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force these to always use LF
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
.husky/*    text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
